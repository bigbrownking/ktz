# Скопируйте в .env и подстройте под окружение (docker compose подхватывает .env из корня).

# --- Порты сервисов ---
SIMULATOR_PORT=8081
TELEMETRY_PORT=8082
HISTORY_PORT=8083
GATEWAY_PORT=8080

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- PostgreSQL ---
POSTGRES_DB=ktz
POSTGRES_USER=ktz
POSTGRES_PASSWORD=ktz
POSTGRES_URL=jdbc:postgresql://postgres:5432/ktz

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO ---
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET=users

# --- JWT (замените на свой секрет в проде) ---
JWT_SECRET=change-me
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- Симулятор локомотивов ---
TELEMETRY_FREQUENCY_HZ=1
LOCO_1_NUMBER=TE33A-001
LOCO_1_TYPE=TE33A
LOCO_1_NAME=Астана-Кокшетау
LOCO_1_START_LAT=51.18
LOCO_1_START_LON=71.45
LOCO_1_END_LAT=53.31
LOCO_1_END_LON=69.39
LOCO_2_NUMBER=KZ8A-007
LOCO_2_TYPE=KZ8A
LOCO_2_NAME=Алматы-Шымкент
LOCO_2_START_LAT=43.25
LOCO_2_START_LON=76.93
LOCO_2_END_LAT=42.30
LOCO_2_END_LON=69.60

# --- Next.js (ktz-web): не используются docker-compose напрямую ---
# Скопируйте эти строки в ktz-web/.env.local — URL должны быть доступны из браузера.
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_TELEMETRY_WS_URL=ws://localhost:8082
