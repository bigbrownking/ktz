# Скопируйте в .env.local и подставьте URL, доступные из браузера (не имена Docker-сервисов).
# NEXT_PUBLIC_* вшиваются в клиентский бандл на этапе сборки.

# Gateway (REST, JWT): локально обычно порт из GATEWAY_PORT в корневом .env
NEXT_PUBLIC_API_URL=http://localhost:8080

# Телеметрия (WebSocket): порт ktz-telemetry (TELEMETRY_PORT)
NEXT_PUBLIC_TELEMETRY_WS_URL=ws://localhost:8082
